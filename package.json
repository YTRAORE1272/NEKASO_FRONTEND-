{
  "name": "nekasofrontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write --experimental-cli src/",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test --config=playwright.config.cjs",
    "test:security": "node ./scripts/security-check.cjs",
    "test:compat": "playwright test --config=playwright.config.cjs --project=chromium --project=firefox --project=webkit",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.4",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
